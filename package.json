{
  "name": "php-brauzer",
  "version": "1.1.5",
  "description": "Electron browser for local PHP landing pages",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.php-brauzer.app",
    "productName": "PHP Browser",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "router.php",
      "editor.js",
      "editor-theme.css",
      "terminal-panel.js",
      "features.js",
      "index.html",
      "package.json",
      "node_modules/codemirror/**/*",
      "node_modules/@xterm/**/*",
      "node_modules/node-pty/**/*"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "router.php",
      "node_modules/node-pty/**/*"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^5.65.21",
    "node-pty": "^1.1.0"
  }
}
